# Copia este archivo a .env y rellena los valores antes de arrancar la web.

# Obligatoria — contraseña única para entrar en la web.
TRANSCRIBER_PASSWORD=changeme

# Obligatoria — firma las cookies de sesión. Genera una con:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Opcional — tamaño máximo de subida en MB (por defecto 2048 = 2GB).
MAX_UPLOAD_MB=2048

# Opcional — minutos que se conservan los trabajos terminados antes de borrarse (por defecto 60).
JOB_TTL_MINUTES=60

# Opcional — carpeta donde se guardan los vídeos subidos y los .srt resultantes.
UPLOAD_DIR=/tmp/transcriber_jobs

# Opcional — pon "false" solo en desarrollo local sin HTTPS.
SESSION_HTTPS_ONLY=true

# Opcional — puerto en el que escucha uvicorn (el Dockerfile usa 8000 por defecto).
PORT=8000
